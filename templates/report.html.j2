          </thead>
          <tbody>
            {% for u in costs.top_users_by_cost %}
            <tr>
              <td>{{ u.email }}</td>
              <td class="number">{{ u.scopes }}</td>
              <td class="number">${{ "%.2f"|format(u.avg_cost) }}</td>
